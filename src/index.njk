---
layout: layouts/base.njk
title: "Inicio - Curso de IA"
---

<section class="hero">
  <h1>{{ site.title }}</h1>
  <p>{{ site.description }}</p>
</section>

<ul class="post-grid">
  {%- for post in collections.clase -%}
    <li class="post-card">
      <small>{{ post.date | dateFilter }}</small>
      <a href="{{ post.url }}">{{ post.data.title }}</a>
      
      {# Si el artículo tiene descripción, la muestra #}
      <p>{{ post.data.description | default("Haz clic para leer más sobre este tema...") }}</p>
      
      <span class="read-more">Leer artículo →</span>
    </li>
  {%- endfor -%}
</ul>
